+You are an expert in genetic programming and Freqtrade strategy evolution.
+
+Task: Create the core evolution engine script that generates and mutates valid logic trees (genomes) compatible with user_data/strategies/GPTreeStrategy.py and user_data/strategies/gp_blocks.py.
+
+Target file: scripts/evolution_engine.py
+
+Requirements:
+
+1. Constants (define at module level):
+   OPERATORS = ["AND", "OR", "NOT"]
+   COMPARATORS = ["GREATER_THAN", "LESS_THAN", "CROSS_UP", "CROSS_DOWN"]
+   INDICATORS = ["RSI", "EMA", "SMA", "BB_UPPER", "BB_MIDDLE", "BB_LOWER"]
+
+2. def generate_random_tree(max_depth: int, current_depth: int = 0) -> dict:
+   - Recursive function that returns a valid nested dictionary node
+   - If current_depth >= max_depth:
+     return random indicator primitive with randomized parameters
+   - Else:
+     Choose randomly between:
+       - creating an Operator node (probability ~0.6)
+       - creating a Comparator node (probability ~0.4)
+   - For Operator node:
+     - op = random.choice(OPERATORS)
+     - if op == "NOT": children = [generate_random_tree(max_depth, current_depth+1)]  (exactly 1 child)
+     - else: children = [generate_random_tree(max_depth, current_depth+1) for _ in range(2)]
+     - return {"operator": op, "children": children}
+   - For Comparator node:
+     - comp = random.choice(COMPARATORS)
+     - left = random indicator primitive (generate_random_tree(max_depth, current_depth+1) but force indicator)
+     - right = random indicator primitive (same)
+     - return {"primitive": comp, "left": left, "right": right}
+   - For leaf (indicator) nodes:
+     - indicator = random.choice(INDICATORS)
+     - parameters = {}
+     - if indicator in ["RSI", "EMA", "SMA"]: parameters["window"] = random.randint(7, 50)
+     - if indicator in ["BB_UPPER", "BB_MIDDLE", "BB_LOWER"]:
+       parameters["window"] = random.randint(10, 40)
+       parameters["std"] = round(random.uniform(1.5, 3.0), 1)
+     - return {"primitive": indicator, "parameters": parameters}
+
+3. def mutate_tree(tree: dict, mutation_rate: float = 0.1) -> dict:
+   - Return a deep copy of the input tree with mutations applied
+   - Recursively traverse every node with probability mutation_rate per node
+   - Mutation types (choose one randomly when mutating a node):
+     - Point mutation (40%): 
+       - if indicator → perturb one numeric parameter (window ±1 to ±5, clamp 5–60; std ±0.2 to ±0.5, clamp 1.0–4.0)
+       - if comparator → change to different comparator from COMPARATORS (uniform)
+     - Subtree replacement (30%): replace entire subtree with generate_random_tree(max_depth=original_subtree_depth_estimate)
+     - Branch swap (15%): if node has left/right or children[0]/children[1] → swap them
+     - Operator change (10%): if operator node → change AND ↔ OR (NOT stays NOT)
+     - Insert wrapper (5%): wrap current node in new AND/OR with extra random child
+   - After each change, ensure structural validity (correct keys, child count)
+   - Use copy.deepcopy to avoid mutating original
+
+4. Genome file utilities:
+   def save_genome(genome: dict, path: str = "user_data/current_genome.json") -> None:
+     - Create parent directories if needed
+     - Write pretty JSON (indent=2)
+   def load_genome(path: str = "user_data/current_genome.json") -> dict:
+     - Return json.load if file exists, else raise FileNotFoundError
+
+5. Main guard (for testing):
+   if __name__ == "__main__":
+     import json
+     print("Generating random tree (max_depth=3)...")
+     tree = generate_random_tree(max_depth=3)
+     print(json.dumps(tree, indent=2))
+     print("\nMutating tree...")
+     mutated = mutate_tree(tree, mutation_rate=0.3)
+     print(json.dumps(mutated, indent=2))
+     save_genome(tree, "user_data/current_genome_test.json")
+
+Constraints:
+- All node types and string names MUST match exactly what GPTreeStrategy.evaluate_node expects
+- Comparators consume only numeric Series (from indicators)
+- Operators consume only boolean Series (from comparators or other operators)
+- Use only import random, json, os, copy, typing (Dict, Any)
+- No external dependencies
+- Add type hints and short docstrings to main functions
+- When generating parameters, keep values realistic and safe for pandas_ta
+- Ensure mutated trees remain evaluable without raising structural errors

